# ============================================================
# FILLINUS ERP — Required Environment Variables
# ============================================================
# Copy this file to .env for local development.
# NEVER commit your actual .env file to Git.
# ============================================================

# ─── DATABASE ─────────────────────────────────────────────
# On Railway: automatically injected by the PostgreSQL plugin
# On local: use the docker-compose PostgreSQL instance
DATABASE_URL=jdbc:postgresql://localhost:5432/fillinus_erp
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ─── JWT ──────────────────────────────────────────────────
# MUST be at least 32 characters. Change this in production!
JWT_SECRET=fillinus-erp-change-this-to-a-very-long-random-secret-key
JWT_EXPIRATION_MS=86400000

# ─── EMAIL (for Forgot Password) ──────────────────────────
# Use Mailtrap.io for development:
# https://mailtrap.io → create inbox → copy SMTP credentials
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password

# ─── APPLICATION ──────────────────────────────────────────
# Used in password reset email links
APP_BASE_URL=http://localhost:8080

# Token expires after N minutes (default: 30)
RESET_TOKEN_EXPIRY_MINUTES=30

# ─── SERVER ───────────────────────────────────────────────
# Railway injects PORT automatically. Only set this locally if needed.
PORT=8080
